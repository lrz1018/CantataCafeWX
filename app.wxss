page {
  min-height: 100vh;
  color: #1f1f1f;
  background: #f6f4ef;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
}

.section {
  margin-top: 32rpx;
}

.section-title {
  color: #1f1f1f;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.3;
}

.muted {
  color: #777777;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  padding: 0 32rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #7a4d2b;
  font-size: 30rpx;
  font-weight: 600;
}

.primary-button::after {
  border: 0;
}

.ghost-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  padding: 0 28rpx;
  border: 2rpx solid #d8d0c4;
  border-radius: 8rpx;
  color: #1f1f1f;
  background: transparent;
  font-size: 28rpx;
}

.ghost-button::after {
  border: 0;
}
