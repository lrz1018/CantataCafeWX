<view class="page profile-page">
  <view class="profile-header">
    <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar">{{userInitial}}</view>
    <view class="profile-main">
      <view class="nickname">{{nickname}}</view>
      <view class="muted">Cantata Cafe 会员</view>
    </view>
  </view>

  <view class="section">
    <view class="section-title">账户</view>
    <view class="action-list">
      <button wx:if="{{!loggedIn}}" class="action-row" bindtap="login">微信登录</button>
      <button wx:else class="action-row" bindtap="logout">退出登录</button>
      <button class="action-row" bindtap="clearCart">清空购物车</button>
    </view>
  </view>

  <view class="section">
    <view class="section-title">资料</view>
    <view class="form-list">
      <view class="form-row">
        <view class="form-label">昵称</view>
        <input class="form-input" value="{{nickname}}" maxlength="80" bindinput="onNicknameInput" placeholder="请输入昵称" />
      </view>
      <view class="form-row">
        <view class="form-label">手机号</view>
        <input class="form-input" value="{{phone}}" maxlength="32" bindinput="onPhoneInput" placeholder="请输入手机号" />
      </view>
    </view>
    <button class="primary-button save-button" loading="{{saving}}" disabled="{{saving}}" bindtap="saveProfile">保存资料</button>
  </view>
</view>
