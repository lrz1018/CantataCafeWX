<view class="page orders-page">
  <view wx:if="{{loading}}" class="empty">
    <view class="empty-title">订单加载中...</view>
  </view>

  <view wx:elif="{{loginRequired}}" class="empty">
    <view class="empty-title">登录后查看订单</view>
    <view class="empty-desc">完成点单后会出现在这里。</view>
    <button class="primary-button empty-action" bindtap="loginAndLoad">微信登录</button>
  </view>

  <block wx:else>
    <view
      wx:for="{{orders}}"
      wx:key="id"
      class="order-item"
      bindtap="openDetail"
      data-id="{{item.id}}"
    >
      <view class="order-header">
        <view class="order-number">{{item.number}}</view>
        <view class="order-status">{{item.statusText}}</view>
      </view>
      <view class="order-products">{{item.products}}</view>
      <view class="order-footer">
        <text>{{item.createdAtText}}</text>
        <text class="order-total">{{item.totalText}}</text>
      </view>
    </view>
  </block>

  <view wx:if="{{!loading && !loginRequired && !orders.length}}" class="empty">
    <view class="empty-title">暂无订单</view>
    <view class="empty-desc">完成点单后会出现在这里。</view>
  </view>
</view>
