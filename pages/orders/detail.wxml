<view class="page order-detail-page">
  <view wx:if="{{loading && !order}}" class="state">订单加载中...</view>
  <view wx:elif="{{error && !order}}" class="state error">{{error}}</view>

  <block wx:else>
    <view class="detail-header">
      <view>
        <view class="pickup-label">取餐号</view>
        <view class="pickup-no">{{order.pickupNo}}</view>
      </view>
      <view class="status-group">
        <view class="status">{{order.statusText}}</view>
        <view class="payment-status">{{order.paymentStatusText}}</view>
      </view>
    </view>

    <view class="info-row">
      <text>下单时间</text>
      <text>{{order.createdAtText}}</text>
    </view>
    <view wx:if="{{order.paidAtText}}" class="info-row">
      <text>支付时间</text>
      <text>{{order.paidAtText}}</text>
    </view>
    <view class="info-row">
      <text>支付状态</text>
      <text>{{order.paymentStatusText}}</text>
    </view>
    <view wx:if="{{order.remark}}" class="info-row remark-row">
      <text>备注</text>
      <text>{{order.remark}}</text>
    </view>

    <view class="section">
      <view class="section-title">商品快照</view>
      <view class="item-list">
        <view wx:for="{{order.items}}" wx:key="productId" class="order-product">
          <view>
            <view class="product-name">{{item.productName}}</view>
            <view class="product-meta">{{item.unitPriceText}} x {{item.quantity}}</view>
          </view>
          <view class="subtotal">{{item.subtotalText}}</view>
        </view>
      </view>
      <view wx:if="{{order.hasDiscount}}" class="amount-list">
        <view class="amount-row">
          <text>原价</text>
          <text>{{order.originalTotalText}}</text>
        </view>
        <view class="amount-row">
          <text>{{order.memberCard.name}} · {{order.memberCard.discountProductName}}</text>
          <text>-{{order.discountText}}</text>
        </view>
      </view>
      <view class="total">实付 {{order.totalText}}</view>
    </view>

    <view wx:if="{{order.showPaymentAction}}" class="actions">
      <button
        class="primary-button action-button"
        bindtap="handleOrderPayment"
        loading="{{paying}}"
        disabled="{{paying}}"
      >
        {{order.paymentActionText}}
      </button>
    </view>
  </block>
</view>
