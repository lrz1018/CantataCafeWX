<view class="page cart-page">
  <block wx:if="{{cart.length}}">
    <view class="cart-list">
      <view wx:for="{{cart}}" wx:key="id" class="cart-item">
        <view class="item-main">
          <view class="item-name">{{item.name}}</view>
          <view class="item-price">{{item.priceText}}</view>
          <view wx:if="{{item.stockEnabled}}" class="item-stock">剩余 {{item.stockQuantity}}</view>
        </view>
        <view class="counter">
          <button class="counter-button" bindtap="decrease" data-id="{{item.productId}}">-</button>
          <text class="count">{{item.quantity}}</text>
          <button class="counter-button" bindtap="increase" data-id="{{item.productId}}">+</button>
        </view>
      </view>
    </view>

    <view class="remark-block">
      <view class="remark-label">订单备注</view>
      <textarea
        class="remark-input"
        value="{{remark}}"
        maxlength="255"
        placeholder="例如：少冰、少糖"
        bindinput="onRemarkInput"
      />
      <view class="remark-count">{{remarkLength}}/255</view>
    </view>

    <view class="summary">
      <view>
        <view class="summary-label">合计</view>
        <view class="summary-price">{{totalText}}</view>
      </view>
      <button class="primary-button checkout-button" loading="{{submitting}}" disabled="{{submitting}}" bindtap="checkout">
        {{submitting ? '提交中' : '提交订单'}}
      </button>
    </view>
  </block>

  <view wx:else class="empty">
    <view class="empty-title">购物车为空</view>
    <view class="empty-desc">去菜单挑选一杯咖啡。</view>
    <button class="primary-button empty-action" bindtap="goMenu">去点单</button>
  </view>
</view>
