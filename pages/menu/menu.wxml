<view class="page menu-page">
  <view class="menu-hero">
    <view class="top-row">
      <view class="time-space"></view>
      <view class="page-title">在线点单</view>
      <view class="more-button">
        <view class="more-dot"></view>
        <view class="more-dot"></view>
        <view class="more-dot"></view>
      </view>
    </view>

    <view class="search-box">
      <input
        class="search-input"
        value="{{searchKeyword}}"
        placeholder="搜索咖啡、甜品、轻食"
        placeholder-class="search-placeholder"
        confirm-type="search"
        bindinput="handleSearchInput"
      />
      <view wx:if="{{searchKeyword}}" class="search-clear" catchtap="clearSearch">×</view>
    </view>

    <scroll-view class="category-bar" scroll-x="true" show-scrollbar="false">
      <view class="category-list">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="category-item {{activeCategoryId === item.id ? 'active' : ''}}"
          bindtap="selectCategory"
          data-id="{{item.id}}"
        >
          {{item.name}}
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{loading}}" class="state">菜单加载中...</view>
  <view wx:elif="{{error}}" class="state error">{{error}}</view>
  <view wx:elif="{{!categories.length || !products.length}}" class="state">暂无可点商品</view>
  <view wx:elif="{{!filteredProducts.length}}" class="state">当前分类暂无商品</view>

  <view wx:else class="product-list">
    <view class="section-title">{{sectionTitle}}</view>
    <view
      wx:for="{{filteredProducts}}"
      wx:key="id"
      class="product-card"
      bindtap="openProduct"
      data-id="{{item.id}}"
    >
      <view class="product-media">
        <image
          wx:if="{{item.imageSrc}}"
          class="product-image"
          src="{{item.imageSrc}}"
          mode="aspectFill"
        />
        <view wx:else class="cup-icon">
          <view class="cup-body"></view>
          <view class="cup-handle"></view>
        </view>
      </view>

      <view class="product-main">
        <view class="product-name">{{item.name}}</view>
        <view class="product-desc">{{item.description || '热 / 冰 · 甜度可调'}}</view>
        <view class="product-price">{{item.priceText}}</view>
      </view>

      <view class="product-counter">
        <button class="quantity-button minus" catchtap="decrease" data-id="{{item.id}}">−</button>
        <text class="quantity-count">{{item.cartQuantity}}</text>
        <button class="quantity-button plus {{item.soldOut ? 'disabled' : ''}}" catchtap="addToCart" data-id="{{item.id}}">+</button>
      </view>
    </view>
  </view>

  <view wx:if="{{cartSheetVisible}}" class="cart-sheet-mask" catchtap="closeCartSheet"></view>
  <view wx:if="{{cartSheetVisible}}" class="cart-sheet" catchtap="stopPropagation">
    <view class="cart-sheet-header">
      <view class="cart-sheet-heading">
        <view class="cart-sheet-title">购物车</view>
        <view class="cart-sheet-subtitle">{{cart.length ? '调整商品数量' : '购物车为空'}}</view>
      </view>
      <button class="cart-sheet-close" aria-label="关闭购物车" catchtap="closeCartSheet">
        <view class="cart-sheet-close-icon"></view>
      </button>
    </view>

    <block wx:if="{{cart.length}}">
      <view class="cart-list">
        <view wx:for="{{cart}}" wx:key="productId" class="cart-item">
          <view class="cart-item-main">
            <view class="cart-item-name">{{item.name}}</view>
            <view class="cart-item-price">{{item.priceText}}</view>
            <view wx:if="{{item.stockEnabled}}" class="cart-item-stock">剩余 {{item.stockQuantity}}</view>
          </view>
          <view class="counter">
            <button class="counter-button" catchtap="decrease" data-id="{{item.productId}}">-</button>
            <text class="count">{{item.quantity}}</text>
            <button class="counter-button" catchtap="increase" data-id="{{item.productId}}">+</button>
          </view>
        </view>
      </view>

      <view class="member-card-checkout">
        <view class="member-card-header">
          <view>
            <view class="member-card-title">会员卡优惠</view>
            <view class="member-card-subtitle">{{memberCardLoading ? '加载中...' : memberCardSummary}}</view>
          </view>
          <view wx:if="{{selectedMemberCardId}}" class="member-card-clear" catchtap="clearMemberCard">不使用</view>
        </view>

        <view wx:if="{{memberCardError}}" class="member-card-empty">{{memberCardError}}</view>
        <view wx:elif="{{!availableMemberCards.length}}" class="member-card-empty">暂无可用会员卡</view>
        <scroll-view wx:else class="member-card-scroll" scroll-x="true" show-scrollbar="false">
          <view class="member-card-options">
            <view
              wx:for="{{availableMemberCards}}"
              wx:key="id"
              class="member-card-option {{selectedMemberCardId === item.id ? 'selected' : ''}}"
              catchtap="selectMemberCard"
              data-id="{{item.id}}"
            >
              <view class="member-card-option-name">{{item.name}}</view>
              <view class="member-card-option-meta">{{item.typeText}} · {{item.discountProductName}}</view>
              <view class="member-card-option-discount">预计优惠 {{item.discountText}}</view>
            </view>
          </view>
        </scroll-view>

        <view wx:if="{{selectedMemberCard}}" class="member-card-estimate">
          <view class="estimate-row">
            <text>优惠商品</text>
            <text>{{selectedMemberCard.discountProductName}}</text>
          </view>
          <view class="estimate-row">
            <text>预计优惠</text>
            <text>-{{discountText}}</text>
          </view>
          <view class="estimate-row payable">
            <text>预计实付</text>
            <text>{{estimatedPayableText}}</text>
          </view>
        </view>
      </view>
    </block>

    <view wx:else class="cart-empty">
      <view class="cart-empty-title">购物车为空</view>
      <view class="cart-empty-desc">从菜单中添加喜欢的咖啡。</view>
    </view>
  </view>

  <view class="checkout-bar">
    <view class="checkout-summary" bindtap="openCartSheet">
      <view class="summary-icon">
        <view class="summary-cup">
          <view class="summary-cup-body"></view>
          <view class="summary-cup-handle"></view>
        </view>
      </view>
      <view class="summary-text">
        <view class="summary-count">已选 {{totalCount}} 件</view>
        <view class="summary-total">合计 {{totalText}}</view>
      </view>
    </view>
    <view
      class="checkout-button {{submitting || !cart.length ? 'disabled' : ''}}"
      catchtap="checkoutFromBar"
    >
      {{submitting ? '提交中' : '去结算'}}
    </view>
  </view>
</view>
