.menu-page {
  padding-top: 24rpx;
}

.banner-swiper {
  height: 260rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 8rpx;
}

.banner-image {
  width: 100%;
  height: 260rpx;
  background: #e4d8c9;
}

.category-bar {
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 16rpx;
  padding-bottom: 20rpx;
}

.category-item {
  flex: none;
  min-width: 128rpx;
  height: 64rpx;
  padding: 0 28rpx;
  border: 2rpx solid #d8d0c4;
  border-radius: 8rpx;
  color: #4a4a4a;
  background: #ffffff;
  font-size: 26rpx;
  line-height: 60rpx;
  text-align: center;
}

.category-item.active {
  border-color: #1f1f1f;
  color: #ffffff;
  background: #1f1f1f;
}

.product-list {
  margin-top: 12rpx;
  padding: 0 4rpx 48rpx;
}

.state {
  padding: 120rpx 24rpx;
  color: #777777;
  text-align: center;
}

.state.error {
  color: #7a4d2b;
}
