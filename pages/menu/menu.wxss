.menu-page {
  padding-top: 24rpx;
  padding-bottom: 132rpx;
}

.banner-swiper {
  height: 260rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 8rpx;
}

.banner-image {
  width: 100%;
  height: 260rpx;
  background: #e4d8c9;
}

.category-bar {
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 16rpx;
  padding-bottom: 20rpx;
}

.category-item {
  flex: none;
  min-width: 128rpx;
  height: 64rpx;
  padding: 0 28rpx;
  border: 2rpx solid #d8d0c4;
  border-radius: 8rpx;
  color: #4a4a4a;
  background: #ffffff;
  font-size: 26rpx;
  line-height: 60rpx;
  text-align: center;
}

.category-item.active {
  border-color: #1f1f1f;
  color: #ffffff;
  background: #1f1f1f;
}

.product-list {
  margin-top: 12rpx;
  padding: 0 4rpx 80rpx;
}

.state {
  padding: 120rpx 24rpx;
  color: #777777;
  text-align: center;
}

.state.error {
  color: #7a4d2b;
}

.cart-sheet-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 20;
  background: rgba(31, 31, 31, 0.36);
}

.cart-sheet {
  position: fixed;
  right: 0;
  bottom: calc(96rpx + env(safe-area-inset-bottom));
  left: 0;
  z-index: 30;
  max-height: 68vh;
  padding: 28rpx 32rpx 20rpx;
  overflow-y: auto;
  border-radius: 8rpx 8rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -10rpx 32rpx rgba(31, 31, 31, 0.12);
}

.cart-sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding-bottom: 12rpx;
}

.cart-sheet-heading {
  min-width: 0;
}

.cart-sheet-title {
  color: #1f1f1f;
  font-size: 34rpx;
  font-weight: 800;
}

.cart-sheet-subtitle {
  margin-top: 6rpx;
  color: #777777;
  font-size: 24rpx;
}

.cart-sheet-close {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  flex: none;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #f6f4ef;
}

.cart-sheet-close::after {
  border: 0;
}

.cart-sheet-close-icon {
  position: relative;
  width: 24rpx;
  height: 24rpx;
}

.cart-sheet-close-icon::before,
.cart-sheet-close-icon::after {
  position: absolute;
  top: 11rpx;
  left: 1rpx;
  width: 22rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #1f1f1f;
  content: "";
}

.cart-sheet-close-icon::before {
  transform: rotate(45deg);
}

.cart-sheet-close-icon::after {
  transform: rotate(-45deg);
}

.cart-list {
  margin-top: 8rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 26rpx 0;
  border-bottom: 2rpx solid #ebe4da;
}

.cart-item-main {
  min-width: 0;
  flex: 1;
}

.cart-item-name {
  overflow: hidden;
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cart-item-price {
  margin-top: 8rpx;
  color: #7a4d2b;
  font-size: 28rpx;
  font-weight: 700;
}

.cart-item-stock {
  margin-top: 6rpx;
  color: #777777;
  font-size: 22rpx;
}

.counter {
  display: flex;
  flex: none;
  align-items: center;
  gap: 18rpx;
}

.counter-button {
  width: 56rpx;
  height: 56rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  color: #1f1f1f;
  background: #ffffff;
  font-size: 30rpx;
  line-height: 56rpx;
}

.counter-button::after {
  border: 2rpx solid #d8d0c4;
  border-radius: 8rpx;
}

.count {
  width: 44rpx;
  color: #1f1f1f;
  font-size: 28rpx;
  text-align: center;
}

.cart-empty {
  padding: 56rpx 24rpx 64rpx;
  text-align: center;
}

.cart-empty-title {
  color: #1f1f1f;
  font-size: 32rpx;
  font-weight: 700;
}

.cart-empty-desc {
  margin-top: 12rpx;
  color: #777777;
  font-size: 26rpx;
}

.member-card-checkout {
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #ebe4da;
}

.member-card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.member-card-title {
  color: #1f1f1f;
  font-size: 30rpx;
  font-weight: 800;
}

.member-card-subtitle,
.member-card-empty {
  margin-top: 8rpx;
  color: #777777;
  font-size: 24rpx;
}

.member-card-clear {
  flex: none;
  color: #7a4d2b;
  font-size: 24rpx;
  font-weight: 700;
}

.member-card-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.member-card-options {
  display: flex;
  gap: 16rpx;
}

.member-card-option {
  width: 300rpx;
  flex: none;
  padding: 20rpx;
  border: 2rpx solid #d8d0c4;
  border-radius: 8rpx;
  background: #ffffff;
}

.member-card-option.selected {
  border-color: #7a4d2b;
  background: #fff7ec;
}

.member-card-option-name {
  overflow: hidden;
  color: #1f1f1f;
  font-size: 28rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-card-option-meta {
  margin-top: 8rpx;
  overflow: hidden;
  color: #777777;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-card-option-discount {
  margin-top: 12rpx;
  color: #7a4d2b;
  font-size: 24rpx;
  font-weight: 800;
}

.member-card-estimate {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 8rpx;
  background: #f6f4ef;
}

.estimate-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  color: #777777;
  font-size: 24rpx;
  line-height: 1.7;
}

.estimate-row.payable {
  color: #1f1f1f;
  font-size: 28rpx;
  font-weight: 800;
}

.cart-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 40;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  min-height: 80rpx;
  padding: 8rpx 32rpx calc(8rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -8rpx 24rpx rgba(31, 31, 31, 0.08);
}

.cart-total {
  min-width: 0;
  height: 60rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.cart-total-label {
  color: #777777;
  font-size: 22rpx;
}

.cart-total-price {
  margin-top: 2rpx;
  color: #7a4d2b;
  font-size: 34rpx;
  font-weight: 800;
}

.checkout-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 60rpx;
  flex: none;
  align-self: center;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  color: #ffffff;
  background: #7a4d2b;
  font-size: 24rpx;
  font-weight: 600;
}

.checkout-button.disabled {
  opacity: 0.55;
}
