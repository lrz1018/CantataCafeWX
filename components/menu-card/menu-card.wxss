.menu-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #ebe4da;
}

.image-wrap {
  width: 156rpx;
  height: 156rpx;
  flex: none;
  overflow: hidden;
  border-radius: 8rpx;
  background: #e4d8c9;
}

.product-image,
.image-placeholder {
  width: 156rpx;
  height: 156rpx;
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7a4d2b;
  font-size: 52rpx;
  font-weight: 700;
}

.content {
  min-width: 0;
  flex: 1;
}

.name {
  color: #1f1f1f;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.3;
}

.desc {
  min-height: 72rpx;
  margin-top: 8rpx;
  color: #777777;
  font-size: 24rpx;
  line-height: 1.45;
}

.meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.price {
  color: #7a4d2b;
  font-size: 32rpx;
  font-weight: 700;
}

.stock {
  margin-top: 4rpx;
  color: #777777;
  font-size: 22rpx;
}

.stock.sold-out {
  color: #b45a3c;
}

.add-button {
  min-width: 112rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 22rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #1f1f1f;
  font-size: 24rpx;
  line-height: 56rpx;
}

.add-button::after {
  border: 0;
}

.add-button.disabled {
  color: #777777;
  background: #ebe4da;
}
